<faces-config
    xmlns="https://jakarta.ee/xml/ns/jakartaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-facesconfig_4_1.xsd"
    version="4.1">

    <!-- A view action navigating to a case which itself declares a redirect must redirect. -->
    <navigation-rule>
        <from-view-id>/spec758-explicit-redirect.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>spec758-explicit-redirect</from-outcome>
            <to-view-id>/spec758-explicit-redirect.xhtml</to-view-id>
            <redirect/>
        </navigation-case>
    </navigation-rule>

    <navigation-rule>
        <from-view-id>/spec758-story.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>homeWithParams</from-outcome>
            <to-view-id>/spec758-home.xhtml</to-view-id>
            <redirect include-view-params="true"/>
        </navigation-case>
        <navigation-case>
            <from-outcome>story2WithParams</from-outcome>
            <to-view-id>/spec758-story2.xhtml</to-view-id>
            <redirect include-view-params="true"/>
        </navigation-case>
    </navigation-rule>

    <navigation-rule>
        <from-view-id>/spec758-story2.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>homeWithParams</from-outcome>
            <to-view-id>/spec758-home.xhtml</to-view-id>
            <redirect include-view-params="true"/>
        </navigation-case>
    </navigation-rule>

    <!-- Kept as a rule of its own: it must not compete with the from-outcome cases above. -->
    <navigation-rule>
        <from-view-id>/spec758-story.xhtml</from-view-id>
        <navigation-case>
            <from-action>#{spec758NewsReader.loadStory}</from-action>
            <if>#{spec758NewsReader.missingStoryId}</if>
            <to-view-id>/spec758-home.xhtml</to-view-id>
            <redirect/>
        </navigation-case>
    </navigation-rule>

</faces-config>
