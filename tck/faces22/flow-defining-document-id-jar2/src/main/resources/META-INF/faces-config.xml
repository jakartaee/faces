<faces-config
    xmlns="https://jakarta.ee/xml/ns/jakartaee"
    xmlns:xsi="http://www.w3.org/2002/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-facesconfig_4_1.xsd"
    version="4.1">

    <!-- The document name is the defining document id of every flow declared below. -->
    <name>flow02</name>

    <flow-definition id="bounded-task-flow">
        <flow-return id="taskFlowReturn1">
            <from-outcome>#{issue2584Bean02.returnValue}</from-outcome>
        </flow-return>
        <flow-call id="call-flow-01">
            <flow-reference>
                <flow-document-id>flow01</flow-document-id>
                <flow-id>bounded-task-flow</flow-id>
            </flow-reference>
        </flow-call>
    </flow-definition>

</faces-config>
